# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# local proof storage (dev only)
.proof-store/

# typescript
*.tsbuildinfo
next-env.d.ts

# Synced ACIR artifacts from nargo (regenerated by `npm run sync-circuits`)
/public/circuits/

# Synced dictionary metadata (from `npm run dict:build`)
/public/dictionary/

# Synced Tesseract assets (from `npm run sync-tesseract`)
/public/tesseract/
/public/tesseract-core/
/public/tesseract-lang/
